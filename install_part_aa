#!/bin/bash
set -e

TARGET_DIR="/Users/dsdxc/www/video"

echo "🎬 沙雕动画开发工具 - 安装中..."
echo "   目标目录: $TARGET_DIR"
echo ""

mkdir -p "$TARGET_DIR"

# 找到 payload 起始行
ARCHIVE=$(awk '/^__PAYLOAD_BELOW__/{print NR+1; exit 0}' "$0")
tail -n +$ARCHIVE "$0" | base64 -d | tar xzf - -C "$TARGET_DIR"

cd "$TARGET_DIR"

if [ ! -f .env.local ]; then
    ENCRYPTION_KEY=$(openssl rand -hex 32)
    echo "ENCRYPTION_KEY=$ENCRYPTION_KEY" > .env.local
    echo "✅ 已生成加密密钥"
fi

echo ""
echo "📦 安装依赖..."
pnpm install

echo ""
echo "✅ 安装完成！"
echo ""
echo "启动开发服务器："
echo "  cd $TARGET_DIR && pnpm dev"
echo ""
echo "启动 Remotion Studio："
echo "  cd $TARGET_DIR && npx remotion studio"
echo ""
exit 0

__PAYLOAD_BELOW__
